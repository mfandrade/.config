# Theme 
theme = light:Builtin Tango Light,dark:Builtin Tango Dark

# Shaders
custom-shader = shaders/cursor_warp.glsl

# Font
font-size = 12
font-family = JetBrainsMono Nerd Font
font-family-bold = JetBrainsMono Nerd Font
font-family-italic = JetBrainsMono Nerd Font Italic
font-family-bold-italic = JetBrainsMono Nerd Font Bold Italic

# Look and feel
background-blur = true
background-opacity = 0.8
bold-is-bright = false
cursor-invert-fg-bg = true
cursor-style-blink = true
cursor-style = block

# Window
gtk-tabs-location = bottom
window-decoration = none
window-new-tab-position = end
window-show-tab-bar = auto

# Shell
shell-integration = fish
shell-integration-features = ssh-terminfo,ssh-env
confirm-close-surface = false

# Keybinds

# essentials
keybind = clear
keybind = ctrl+shift+c=copy_to_clipboard
keybind = ctrl+shift+v=paste_from_clipboard
keybind = ctrl+shift+comma=reload_config
keybind = ctrl+equal=increase_font_size:1
keybind = ctrl+minus=decrease_font_size:1
keybind = ctrl+0=reset_font_size

# splits 
keybind = ctrl+alt+backslash=new_split:right
keybind = ctrl+alt+minus=new_split:down
keybind = ctrl+alt+equal=equalize_splits
keybind = ctrl+alt+z=toggle_split_zoom

# nav
keybind = ctrl+alt+h=goto_split:left
keybind = ctrl+alt+j=goto_split:bottom
keybind = ctrl+alt+k=goto_split:top
keybind = ctrl+alt+l=goto_split:right

# resize
keybind = ctrl+alt+shift+h=resize_split:left,30
keybind = ctrl+alt+shift+j=resize_split:down,30
keybind = ctrl+alt+shift+k=resize_split:up,30
keybind = ctrl+alt+shift+l=resize_split:right,30
keybind = ctrl+alt+backspace=equalize_splits

# tabs
keybind = ctrl+alt+c=new_tab
keybind = ctrl+alt+q=close_surface
keybind = ctrl+alt+1=goto_tab:1
keybind = ctrl+alt+2=goto_tab:2
keybind = ctrl+alt+3=goto_tab:3
keybind = ctrl+alt+4=goto_tab:4
keybind = ctrl+alt+5=goto_tab:5
keybind = ctrl+alt+6=goto_tab:6
keybind = ctrl+alt+7=goto_tab:7
keybind = ctrl+alt+8=goto_tab:8
keybind = ctrl+alt+9=goto_tab:9

# fixes
keybind = shift+ctrl+control_right=text:?
